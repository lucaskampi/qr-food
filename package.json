{
  "name": "qr-food",
  "version": "1.0.0",
  "description": "QR Food Service - Microservices-based QR code restaurant menu & ordering system",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nest build",
    "build:all": "npm run build --workspaces",
    "build:menu-service": "nest build menu-service",
    "build:order-service": "nest build order-service",
    "build:kitchen-service": "nest build kitchen-service",
    "build:erp-service": "nest build erp-service",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/apps/menu-service/main",
    "start:menu-service": "nest start menu-service --watch",
    "start:order-service": "nest start order-service --watch",
    "start:kitchen-service": "nest start kitchen-service --watch",
    "start:erp-service": "nest start erp-service --watch",
    "start:all": "concurrently \"npm:start:menu-service\" \"npm:start:order-service\" \"npm:start:kitchen-service\" \"npm:start:erp-service\"",
    "lint": "nest lint",
    "lint:fix": "nest lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./apps/menu-service/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node apps/menu-service/prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/event-emitter": "^2.0.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "winston": "^3.11.0",
    "winston-nestjs": "^1.0.0",
    "@godaddy/terminus": "^4.12.0",
    "dotenv": "^16.4.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "prisma": "^5.9.0",
    "@prisma/client": "^5.9.0",
    "concurrently": "^8.2.2",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "roots": ["<rootDir>/apps/", "<rootDir>/libs/"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@apps/(.*)$": "<rootDir>/apps/$1",
      "^@libs/(.*)$": "<rootDir>/libs/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/*.spec.ts",
      "!**/index.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
