{
  "name": "qr-food",
  "version": "1.0.0",
  "description": "QR Food Service - Microservices-based QR code restaurant menu & ordering system",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "build:menu-service": "nest build menu-service",
    "build:order-service": "nest build order-service",
    "build:kitchen-service": "nest build kitchen-service",
    "build:erp-service": "nest build erp-service",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/apps/menu-service/main",
    "start:menu-service": "nest start menu-service --watch",
    "start:order-service": "nest start order-service --watch",
    "start:kitchen-service": "nest start kitchen-service --watch",
    "start:erp-service": "nest start erp-service --watch",
    "lint": "nest lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/terminus": "^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0",
    "ts-node": "^10.9.1",
    "prisma": "^5.0.0",
    "@prisma/client": "^5.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "roots": ["<rootDir>/apps/", "<rootDir>/libs/"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@apps/(.*)$": "<rootDir>/apps/$1",
      "^@libs/(.*)$": "<rootDir>/libs/$1"
    }
  }
}
